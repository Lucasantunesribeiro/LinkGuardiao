[Unit]
Description=Cloudflared Tunnel for LinkGuardiao
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/cloudflared tunnel --no-autoupdate --url http://127.0.0.1:8080
Restart=always
RestartSec=5
User=linkguardiao
Group=linkguardiao
Environment=HOME=/var/lib/linkguardiao
WorkingDirectory=/var/lib/linkguardiao
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/linkguardiao

[Install]
WantedBy=multi-user.target
